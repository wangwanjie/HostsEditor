            <sparkle:deltas>
                <enclosure url="https://raw.githubusercontent.com/wangwanjie/HostsEditor/main/HostsEditor5-4.delta" sparkle:deltaFrom="4" length="262802" type="application/octet-stream" sparkle:deltaFromSparkleExecutableSize="977808" sparkle:deltaFromSparkleLocales="de,he,ar,el,ja,fa,uk" sparkle:edSignature="GODP0liWdpaQicyLytMOQRZ+VVRqIyhnOf9pbOmgtSTnd8q3AkdZBGm+h1y6Vqtk9zQSnTDoPxdxFoyyWlrLCA==" />
                <enclosure url="https://raw.githubusercontent.com/wangwanjie/HostsEditor/main/HostsEditor5-3.delta" sparkle:deltaFrom="3" length="1245730" type="application/octet-stream" sparkle:deltaFromSparkleExecutableSize="977808" sparkle:deltaFromSparkleLocales="de,he,ar,el,ja,fa,uk" sparkle:edSignature="1cKsOOACnGtPxEc/M/bxjrfql8RRzUtB3aBnUhWg6irQjWLoXqG7R9ziN6U3/XafGa51ApR7G6hgBUVHQ/KuBA==" />
                <enclosure url="https://raw.githubusercontent.com/wangwanjie/HostsEditor/main/HostsEditor5-2.delta" sparkle:deltaFrom="2" length="1405082" type="application/octet-stream" sparkle:deltaFromSparkleExecutableSize="977808" sparkle:deltaFromSparkleLocales="de,he,ar,el,ja,fa,uk" sparkle:edSignature="4Cz9YnNESBNphM9r4gSc1ZFBnjdogHCtdM/l4UF1K3p2uS8O70aeSYgUI2XvEXAZCo61KcDazHxlv7hLrMHbDg==" />
                <enclosure url="https://raw.githubusercontent.com/wangwanjie/HostsEditor/main/HostsEditor5-1.delta" sparkle:deltaFrom="1" length="472950" type="application/octet-stream" sparkle:deltaFromSparkleExecutableSize="977808" sparkle:deltaFromSparkleLocales="de,he,ar,el,ja,fa,uk" sparkle:edSignature="Jl8gFZibBQacKYjFe4duLI5kf9Ib5XkIgSHxZq0dkrIrzhoN3J5wE1P5EsgOCU9UgsiQf+jvCvPbrqQk4WjCBA==" />
